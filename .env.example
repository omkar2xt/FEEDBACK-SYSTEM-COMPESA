# Firebase Configuration - Get these from Firebase Console (https://console.firebase.google.com)
# 1. Create a new Firebase project
# 2. Go to Project Settings (gear icon)
# 3. Copy the Web app config values

VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional: OpenAI Proxy Endpoint (for AI sentiment analysis)
VITE_OPENAI_PROXY_ENDPOINT=/api/analyze
